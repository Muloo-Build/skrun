NODE_ENV=development
HOST=0.0.0.0
PORT=4000

# Runtime auth secret for Railway and gateway calls.
# In local dev, you can leave this unset and use "dev-token" instead.
SKRUN_API_TOKEN=replace-with-a-long-random-token

# Namespace used when SKRUN_API_TOKEN is enabled.
SKRUN_NAMESPACE=muloo

# Optional local directory for persisted bundles and registry metadata.
# On Railway, point this at your mounted volume path if you want push/pull data to survive deploys.
SKRUN_DATA_DIR=.skrun-data

# Optional browser origin for public gateway consumers.
CORS_ORIGIN=http://localhost:3000

# Provider API keys used by the runtime when caller-supplied keys are not passed.
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Optional additional provider keys already supported by Skrun.
# MISTRAL_API_KEY=
# GROQ_API_KEY=

# Reserved for future HubSpot-backed Muloo skills. Keep these backend-only.
HUBSPOT_PRIVATE_APP_TOKEN=your-hubspot-private-app-token
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret
HUBSPOT_REDIRECT_URI=http://localhost:4000/oauth/hubspot/callback
